# Backend

# ── Postgres (Docker local) ──
# Si corrés el backend con `npm run dev` desde el host: usá localhost.
# Si dockerizás el backend en el futuro: cambiá @localhost por @postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce"

# ── MongoDB (para Bloque 3 - UserProfile) ──
MONGO_URL="mongodb://admin:admin@localhost:27017/ecommerce?authSource=admin"

# ── Redis (para Bloque 3 - carrito + sesiones) ──
REDIS_URL="redis://:redispass@localhost:6379"

# ── Auth ──
JWT_SECRET="una_clave_larga_y_dificil_de_adivinar_123456"

# ── MercadoPago (TEST primero) ──
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MP_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── URLs públicas ──
PUBLIC_BASE_URL="http://localhost:3000"
FRONTEND_BASE_URL="http://localhost:5173"
